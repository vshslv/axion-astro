---
/**
 * About.astro — About section (Figma node 801:38029)
 *
 * Structure:
 *   1. Intro band — "About" pill + editorial description that fills
 *      word-by-word from ghost (0.2) → white (1.0) as the user scrolls in.
 *   2. Horizontal gallery — 4 product screenshots laid out as a flex track,
 *      pinned via `position: sticky` (rule #8 approved). Vertical scroll
 *      maps to translateX on the track via GSAP ScrollTrigger, with snap
 *      points centered on each slide and scrub for the magnetic feel.
 *      Active slide swaps in its caption via the canonical hard-mask
 *      pattern (rule #18 / @docs/frontend-conventions.md).
 *
 * Assets:
 *   public/product-screen/product-1.png  — primary dashboard
 *   public/product-screen/product-2.png  — generative canvas
 *   public/product-screen/product-3.png  — index drilldown
 *   public/product-screen/product-4.png  — assistant briefing
 *
 * Typography note (TODO):
 *   The Figma uses Geist Mono on the "About" pill (14px). The brand
 *   licence only ships Geist Sans (--font-display). Falling back to the
 *   system mono stack until Geist Mono is added via @fontsource. Flagged
 *   to the user in chat — same convention as the SF UI Display / Diatype
 *   substitutions called out in CLAUDE.md.
 */

// Split the description into word-tokens so each one can fade in
// independently under the ScrollTrigger scrub. Joined with explicit
// spaces because Astro JSX collapses whitespace between rendered nodes.
const description =
  "Axion is a sovereign decision help system that closes the gap between urban signal and institutional action — sensing what is happening, reasoning over what it means, and acting within the hour.";

const words = description.trim().split(/\s+/);

// Render the description as a single inline-HTML string so we control
// whitespace exactly — Astro's JSX between map iterations adds template
// whitespace around each <span> which collapses to multi-space gaps.
const descHtml = words
  .map((w) => `<span class="about__word">${w}</span>`)
  .join(" ");

// 4 captions — short, editorial, in the brand's voice. Each one swaps
// into the mask when its slide reaches center.
const slides = [
  {
    src: "/product-screen/product-1.png",
    alt: "Cross-domain KPI summary inside the Axion canvas.",
    caption:
      "Cross-domain summary at a glance. Every KPI, every score, every signal — surfaced where the decision is being made.",
  },
  {
    src: "/product-screen/product-2.png",
    alt: "Generative business intelligence workspace with live charts.",
    caption:
      "An infinite canvas for generative business intelligence. Data, insights, and AI-rendered visuals come together as one living workspace.",
  },
  {
    src: "/product-screen/product-3.png",
    alt: "Drilldown into a single index with composition and trend.",
    caption:
      "Drill into a single index without leaving context. Composition, drivers, and historical trend live alongside the headline number.",
  },
  {
    src: "/product-screen/product-4.png",
    alt: "Assistant panel surfacing a plain-language briefing.",
    caption:
      "Ask the assistant. Plain-language briefings rendered on demand from the same canvas, citing the underlying signals.",
  },
];
---

<section class="about" id="about" aria-labelledby="about-tag">
  {/* ───────────────── Intro band ───────────────── */}
  <div class="about__intro">
    <div class="about__intro-inner container">
      <p class="about__tag" id="about-tag">About</p>

      {/* Each word is its own span so GSAP can stagger the opacity ramp
          across the scroll. set:html avoids template-whitespace gaps
          between word-spans. No-JS / reduced-motion users see them all
          fully opaque — the script downgrades to 0.2 on init. */}
      <p class="about__desc" set:html={descHtml} />
    </div>
  </div>

  {/* ───────────────── Gallery ───────────────── */}
  <div class="about__gallery" aria-label="Product gallery">
    {/* Stage is pinned via ScrollTrigger (pin: true). GSAP creates its own
        pin spacer at the configured pin duration — no CSS wrapper height
        hack, no 100svh trail after the last slide. When the pin releases,
        the stage is already gone and Features's --space-section-divider
        padding is the only thing between the last caption and the
        Features pill. */}
    <div class="about__stage" data-stage>
      <div class="about__track-wrap">
        <ul class="about__track" data-track>
          {
            slides.map((slide, i) => (
              <li class="about__slide" data-index={i}>
                {/* skeleton class on the frame paints the B&W shimmer
                    while the image decodes; the script removes it once
                    img.decode() resolves and the image fades in over it. */}
                <figure class="about__frame skeleton">
                  <img
                    class="about__frame-img"
                    src={slide.src}
                    alt={slide.alt}
                    loading="lazy"
                    decoding="async"
                  />
                </figure>
                {/* Mobile-only caption — desktop hides this and uses the
                    single masked caption pinned bottom-center. On mobile
                    the masked single-caption pattern is hard to sync
                    against native scroll-snap, so each slide carries its
                    own caption inline. */}
                <p class="about__slide-caption">{slide.caption}</p>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Caption mask — single mask, 4 caption candidates stacked in
          the same grid cell. Active one at translateY(0), past slides
          cleared upward, queued slides parked below. Same mechanic as
          .custom-cursor__mask in Header. */}
      <div class="about__caption">
        <p class="about__caption-mask" aria-live="polite">
          {
            slides.map((slide, i) => (
              <span
                class="about__caption-text"
                data-index={i}
                data-state={i === 0 ? "active" : "next"}
              >
                {slide.caption}
              </span>
            ))
          }
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  /* ════════════════════════════════════════════════════════════
     Component-local tokens — values lifted from Figma node 801:38029.
     Kept scoped because they're About-specific; if any of these
     repeat in another section, promote to @theme in global.css.
     ════════════════════════════════════════════════════════════ */
  .about {
    /* Frame chrome — 15px radius + 15px padding around each screenshot */
    --frame-radius: 0.9375rem;
    --frame-pad: 0.9375rem;

    /* Description text — Figma 36px / 46px line-height at 1728w,
       scales down to 22px at mobile. Letter-spacing matches Figma -1px. */
    --desc-size: clamp(1.375rem, 0.85rem + 1.85vw, 2.25rem);
    --desc-leading: 1.28;
    --desc-tracking: -0.027em;

    /* Slide width — Figma "center" frame is 1074/1728 = 62% of canvas.
       Fluid so smaller viewports still get the same proportional peek. */
    --slide-w: clamp(17rem, 55vw, 67rem);
    --slide-aspect: 1074 / 679;
    /* Derived slide height — width × (679 / 1074). Used by the gallery's
       centering-offset compensation so the visible slide lands at
       --space-section-divider below the description instead of
       gap + (100svh - slide-h) / 2. */
    --slide-h: calc(var(--slide-w) * 679 / 1074);
    --slide-gap: clamp(1.25rem, 2vw, 2.5rem);

    /* Side-slide visual treatment when not active */
    --slide-side-scale: 0.74; /* matches 794/1074 ≈ 0.74 */
    --slide-side-opacity: 0.55;
  }

  /* ───────────────── Section frame ─────────────────
     Top padding = --space-section-divider (180px desktop / 120px mobile) —
     the gap from the previous section's content end to the "About" pill.
     Same token Features uses for its top padding, so the cross-section
     rhythm is identical. */
  .about {
    position: relative;
    background: var(--color-bg);
    padding-block-start: var(--space-section-divider);
  }

  /* ───────────────── Intro band ─────────────────
     One vertical rhythm for the whole section:
       prev section → "About" pill  = --space-section-divider   (180/120)
       "About" pill → description   = --space-section-title-gap (120/80)
       description  → gallery       = --space-section-divider   (180/120)
       gallery      → Features pill = --space-section-divider   (180/120, from Features)
     Top padding here is 0 — the section-level padding-block-start
     above already provides the lead-in. */
  .about__intro {
    padding-block-end: var(--space-section-divider);
  }

  .about__intro-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    /* Pill → description gap = --space-section-title-gap. Same token
       Features uses for its pill → cards gap, so the rhythm matches. */
    gap: var(--space-section-title-gap);
    text-align: center;
  }

  /* "About" pill — small uppercase-feel mono tag.
     TODO: swap font-family to Geist Mono once @fontsource-variable/geist-mono
     is installed; currently using the system mono stack. */
  .about__tag {
    margin: 0;
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    font-size: var(--text-xs);
    line-height: 1.28;
    color: var(--color-fg);
    opacity: 0.7;
    border: 1px solid var(--color-fg-faint);
    border-radius: 999px;
    padding-block: 0.4375rem 0.5rem; /* figma 7/8 */
    padding-inline: 0.625rem; /* figma 10 */
    inline-size: max-content;
    /* baseline tweak so descenders sit nicely inside the pill */
    text-box-trim: trim-both;
    text-box-edge: cap alphabetic;
  }

  .about__desc {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: var(--desc-size);
    line-height: var(--desc-leading);
    letter-spacing: var(--desc-tracking);
    color: var(--color-fg);
    max-inline-size: 68rem; /* widened from figma 849px → ~1088px per request */
  }

  /* Each word is its own animatable span. Default opacity 1 so
     no-JS users see legible text; GSAP knocks them down to 0.2 on
     init and animates them back to 1 across the scroll range. */
  .about__word {
    display: inline-block;
    opacity: 1;
    will-change: opacity;
  }

  @media (prefers-reduced-motion: reduce) {
    /* Skip the staggered ramp entirely under reduce-motion */
    .about__word {
      opacity: 1 !important;
      /* why: GSAP may have already set inline opacity before
         reduce-motion was applied — force the readable end-state. */
    }
  }

  /* ───────────────── Gallery shell ─────────────────
     No fixed block-size on the wrapper — ScrollTrigger.pin handles the
     vertical scroll distance via its own pin spacer (sized to the pin
     duration: 100% per slide transition). That kills the 100svh trail
     the old CSS-sticky setup left between the last caption and the next
     section: when the pin releases, the stage is already gone and the
     only remaining gap is Features's --space-section-divider padding.

     The negative margin compensates for the slide's centering offset
     inside the 100svh stage. Without it the visible slide lands at
     --space-section-divider + (100svh - --slide-h) / 2 below the
     description (~380px on desktop) — pulling the gallery up by the
     centering offset makes the visible slide land at exactly
     --space-section-divider (180px) below the description. Same
     compensation pattern as .features__card:first-child. */
  .about__gallery {
    position: relative;
    margin-block-start: calc((100svh - var(--slide-h)) / -2);
  }

  .about__stage {
    /* `relative` (not `sticky`) — the pin is driven by ScrollTrigger.
       Still positioned so it acts as the containing block for the
       absolutely-positioned .about__caption (rule #8 — caption pinned
       to the bottom-center of the stage per the design). */
    position: relative;
    /* svh (not vh) so the stage matches the visible viewport on mobile
       Safari even with the toolbar showing. */
    block-size: 100svh;
    inline-size: 100%;
    overflow: hidden;
  }

  .about__track-wrap {
    inline-size: 100%;
    block-size: 100%;
    display: flex;
    align-items: center;
  }

  /* The track itself — flex row of slides. GSAP drives `transform`. */
  .about__track {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: var(--slide-gap);
    will-change: transform;
    /* x is set by JS — first slide centers in the viewport on mount */
  }

  /* ───────────────── Slide ─────────────────
     The slide is a layout cell — width-only on desktop (single child),
     flex column on mobile (frame + inline caption). All the visual chrome
     lives on .about__frame so the caption can sit outside the framed
     image naturally. */
  .about__slide {
    flex: 0 0 auto;
    inline-size: var(--slide-w);

    /* JS drives --slide-scale/-opacity based on distance to viewport
       center (1.0/1.0 active, 0.68/0.5 fully off-center). Falls back
       to the active values pre-script so first paint is correct. */
    --slide-scale: 1;
    --slide-opacity: 1;
    transform: scale(var(--slide-scale));
    opacity: var(--slide-opacity);
    transform-origin: center;
    /* Light synced ease for the residual snap-settle motion. The
       per-frame updates from ScrollTrigger don't need transition
       (they overwrite each frame) — this only smooths sub-pixel
       jitter after snap completes. */
    transition:
      transform 120ms linear,
      opacity 120ms linear;
    will-change: transform, opacity;
  }

  @media (prefers-reduced-motion: reduce) {
    .about__slide {
      transition: none;
    }
  }

  /* ───────────────── Frame (figure) ─────────────────
     Owns ALL the visual chrome — outer border, padding, aspect-ratio,
     and rounded corners. Previously this lived on .about__slide; moved
     here so an inline caption (mobile) can sit outside the framed image
     instead of inheriting the slide's aspect-ratio. Per Figma:
       border  : 0.75px @ 20% white
       radius  : 15px outer (inner image gets a smaller radius below)
       padding : 15px gap between border and screenshot
     box-sizing: border-box so border + padding stay inside inline-size. */
  .about__frame {
    inline-size: 100%;
    aspect-ratio: var(--slide-aspect);
    margin: 0;
    border: 0.75px solid var(--color-fg-faint);
    border-radius: var(--frame-radius);
    padding: var(--frame-pad);
    box-sizing: border-box;
    overflow: hidden;
    background: var(--color-bg-soft);
    position: relative;
  }

  .about__frame-img {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    object-position: center top;
    pointer-events: none;
    user-select: none;
    /* Inner radius is the outer radius minus the padding gap — keeps the
       screenshot's curve concentric with the frame's curve. */
    border-radius: calc(var(--frame-radius) - var(--frame-pad));
    /* The image is always rendered at opacity 1. While src is still
       in flight, the <img> area is transparent and the .skeleton
       shimmer painted on the parent frame shows through. Once the
       browser has pixels for the image it paints them on top of the
       shimmer. JS strips the .skeleton class on `load` to stop the
       animation (saves a tiny amount of compositing work). */
  }

  /* ───────────────── Inline per-slide caption (mobile) ─────────────────
     Hidden on desktop — the masked single-caption (`.about__caption`)
     handles that breakpoint. On small screens the mobile media query
     below flips display to block and tucks it under each frame. */
  .about__slide-caption {
    display: none;
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    color: rgb(255 255 255 / 0.6);
  }

  /* ───────────────── Caption mask ─────────────────
     Pinned to the bottom-center of the sticky stage (rule #8 — viewport-
     anchored UI inside the gallery composition; user authorized). Stays
     stable while slides slide past. Hard-mask text swap (rule #18): all
     four caption strings live in the same grid cell; the active one sits
     at translateY(0). When the active slide changes, JS flips data-state
     on each <span> and the transition does the rest. */
  .about__caption {
    position: absolute;
    inset-block-end: clamp(1.25rem, 3.5svh, 2.75rem);
    inset-inline-start: 50%;
    transform: translateX(-50%);
    inline-size: min(33rem, calc(100% - 2 * var(--page-padding))); /* figma 522px */
    text-align: center;
    /* Above the slide-frame chrome but below any future overlay UI */
    z-index: 2;
    pointer-events: none;
  }

  .about__caption-mask {
    margin: 0;
    display: grid;
    grid-template-areas: "stack";
    overflow: hidden;
    inline-size: 100%;
    /* Cell sizes to the tallest caption candidate — all spans share
       the same grid area so the mask grows to fit whichever caption
       has the most wrapped lines at the current width. */
  }

  .about__caption-text {
    grid-area: stack;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    color: rgb(255 255 255 / 0.6);
    /* Synced motion tokens — caption swap reads as the same gesture
       as every other hover/state swap on the site. */
    transition: transform var(--dur-hover) var(--ease-out-soft);
    /* Default: parked below, ready to slide in */
    transform: translateY(100%);
  }

  /* Active candidate is in the visible window */
  .about__caption-text[data-state="active"] {
    transform: translateY(0);
  }
  /* Already shown — cleared upward through the mask top */
  .about__caption-text[data-state="past"] {
    transform: translateY(-100%);
  }
  /* Queued — parked below, waiting */
  .about__caption-text[data-state="next"] {
    transform: translateY(100%);
  }

  @media (prefers-reduced-motion: reduce) {
    .about__caption-text {
      transition: none;
    }
    /* Show the active caption flat — no animation in reduce-motion */
    .about__caption-text[data-state="active"] {
      transform: translateY(0);
    }
  }

  /* ───────────────── Responsive ─────────────────
     Mobile keeps the desktop pin + horizontal sweep — gesture is
     "vertical scroll → horizontal slide pan", same as the pinned
     desktop experience. The slide width override below widens slides
     to ~85vw so the centered slide is actually readable on a 375px
     screen (the desktop 55vw clamp would resolve to the 17rem floor,
     leaving a tiny 272px slide). */
  @media (max-width: 48em) {
    .about {
      --slide-w: clamp(17rem, 85vw, 32rem);
    }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { ensureLenisBridge } from "../lib/scrollBridge";

  gsap.registerPlugin(ScrollTrigger);
  ensureLenisBridge(ScrollTrigger);

  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const section = document.querySelector<HTMLElement>(".about");

  /* ─────────── Skeleton → reveal on load ───────────
     Every product screenshot frame ships with `.skeleton` (B&W shimmer
     painted from the global utility). We strip the class once the image
     `load` event fires (or immediately if it's already cached), and the
     CSS rule `.about__frame:not(.skeleton) .about__frame-img { opacity: 1 }`
     cross-fades from shimmer to image.

     Note: previous version used img.decode() to guarantee a fully-decoded
     bitmap before reveal. Chromium's lazy-loaded images park decode() in
     a pending state until the image is brought near the viewport, so the
     promise never resolved for off-screen frames — skeleton stuck forever.
     A timeout-raced decode would help, but for our PNGs (non-progressive,
     loaded once) plain `load` is enough — the browser paints them in one
     frame, no flash of partial pixels. */
  if (section) {
    section.querySelectorAll<HTMLElement>(".about__frame.skeleton").forEach((frame) => {
      const img = frame.querySelector<HTMLImageElement>(".about__frame-img");
      if (!img) {
        frame.classList.remove("skeleton");
        return;
      }
      const reveal = (): void => {
        frame.classList.remove("skeleton");
      };
      if (img.complete && img.naturalWidth > 0) {
        reveal();
      } else {
        img.addEventListener("load", reveal, { once: true });
        img.addEventListener("error", reveal, { once: true });
      }
    });
  }

  if (section && !reduceMotion) {
    /* ─────────── Word-by-word fill on the description ─────────── */
    const words = gsap.utils.toArray<HTMLElement>(".about__word", section);
    gsap.set(words, { opacity: 0.2 });
    gsap.to(words, {
      opacity: 1,
      ease: "none",
      stagger: { each: 0.5, from: "start" },
      scrollTrigger: {
        trigger: ".about__intro",
        start: "top 78%",
        end: "bottom 42%",
        scrub: 0.4,
      },
    });

    /* ─────────── Horizontal gallery pin + scrub + snap ───────────
       Runs on both desktop and mobile — gesture is the same
       (vertical scroll drives horizontal slide pan + caption swap).
       Mobile widens slides via @media override on --slide-w. */
    {
      const stage = section.querySelector<HTMLElement>("[data-stage]");
      const track = section.querySelector<HTMLElement>("[data-track]");
      const slides = gsap.utils.toArray<HTMLElement>(".about__slide", section);
      const captions = gsap.utils.toArray<HTMLElement>(".about__caption-text", section);

      if (stage && track && slides.length > 0) {
        const slideCount = slides.length;
        const lastIndex = slideCount - 1;

        /* Helper — compute the x position that centers slide `i` in the stage. */
        const xForSlide = (i: number): number => {
          const slide = slides[i];
          const stageRect = stage.getBoundingClientRect();
          const slideOffsetLeft = slide.offsetLeft;
          const slideWidth = slide.offsetWidth;
          /* The track's current transform shifts the slide's getBoundingClientRect,
             but offsetLeft is layout-only (transform-independent). We compute the
             desired translateX such that the slide's center coincides with the
             stage's center. */
          return stageRect.width / 2 - slideOffsetLeft - slideWidth / 2;
        };

        const initialX = (): number => xForSlide(0);
        const finalX = (): number => xForSlide(lastIndex);

        /* Set the resting position so the first slide is centered before
           the user scrolls into the section. */
        gsap.set(track, { x: initialX() });

        /* Slide scale/opacity + caption state writer — shared by the
           initial paint and the ScrollTrigger onUpdate. Without the
           initial call, slides paint at the CSS defaults (1.0/1.0) the
           moment the gallery enters viewport but BEFORE the pin
           activates and onUpdate fires for the first time — so the
           side slides briefly show at full scale/opacity. Calling it
           once with activeFrac=0 seeds the correct off-center state. */
        const applyGalleryState = (activeFrac: number): void => {
          slides.forEach((slide, i) => {
            const t = Math.min(Math.abs(i - activeFrac), 1);
            const eased = t * t * (3 - 2 * t); /* smoothstep */
            const scale = 1 - (1 - 0.68) * eased;
            const opacity = 1 - (1 - 0.5) * eased;
            slide.style.setProperty("--slide-scale", scale.toFixed(3));
            slide.style.setProperty("--slide-opacity", opacity.toFixed(3));
          });
          const activeIndex = Math.max(
            0,
            Math.min(lastIndex, Math.floor(activeFrac + 0.1))
          );
          captions.forEach((cap, i) => {
            if (i < activeIndex) cap.dataset.state = "past";
            else if (i === activeIndex) cap.dataset.state = "active";
            else cap.dataset.state = "next";
          });
        };

        /* Seed initial state (slide 0 active, slides 1-3 at off-center
           scale/opacity). */
        applyGalleryState(0);

        /* The actual scroll-driven horizontal motion.
           Pin is driven by ScrollTrigger here (not CSS sticky): one
           viewport of scroll per slide transition, no trailing 100svh
           dead zone after the last caption. When pin releases, the
           stage is already gone and Features's --space-section-divider
           padding is the only visible gap before the Features pill. */
        const tween = gsap.fromTo(
          track,
          { x: initialX },
          {
            x: finalX,
            ease: "none",
            scrollTrigger: {
              trigger: stage,
              pin: true,
              pinSpacing: true,
              anticipatePin: 1,
              start: "top top",
              /* Same pin distance the old CSS-sticky setup used:
                 250svh = ~83% per slide transition. Snappier than
                 100% per slide and matches the prior scroll feel. */
              end: `+=${Math.round((slideCount - 1) * 83.33)}%`,
              /* Tight scrub so the track tracks the scrollbar closely
                 (less perceived lag); the snap below provides the
                 settling motion when the user lets go. */
              scrub: 0.2,
              invalidateOnRefresh: true,
              snap: {
                /* Custom snapTo. Root cause of the rollback bug: the previous
                   dir-branch computed `idx - Math.round(idx)` and, when dir=-1
                   and idx=0.55, got distFromCurrent=-0.45 which passed the
                   `dir<0 && dist<-0.04` guard → Math.floor(0.55)=0. That
                   snapped BACKWARD even though the slide was past visual
                   halfway. Removing the dir-branch entirely fixes it.

                   Rule: if velocity is non-trivial, commit in that direction.
                   Otherwise, snap to the nearest slide. Math.round(idx) is
                   "nearest" and naturally handles "visually past halfway" —
                   at idx=0.55, nearest=1 (forward). The delay:0.15 gives
                   Lenis 150 ms to fully decelerate before snap fires, so
                   micro-rollback noise has settled and the position is stable. */
                snapTo: (value, self) => {
                  const idx = value * lastIndex;
                  const velocity = self?.getVelocity?.() ?? 0;
                  /* Lower velocity threshold (30 vs 50) — even a gentle
                     flick commits to the next slide, magnet feels eager. */
                  const target =
                    Math.abs(velocity) > 30
                      ? velocity > 0
                        ? Math.ceil(idx)
                        : Math.floor(idx)
                      : Math.round(idx);
                  return Math.max(0, Math.min(lastIndex, target)) / lastIndex;
                },
                /* Faster pull-in. Min 0.15s = near-instant for short
                   distances; max 0.4s = still smooth for cross-slide
                   snaps but markedly quicker than the previous 0.6s. */
                duration: { min: 0.15, max: 0.4 },
                /* Shorter wait before snap kicks in. 80 ms is still
                   enough for Lenis's micro-rollback to settle but feels
                   immediate to the user. */
                delay: 0.08,
                /* power3.out — strong initial pull (the "magnet")
                   tapering into a soft landing. Replaces inOut which
                   eased symmetrically. */
                ease: "power3.out",
              },
              onUpdate: (self) => {
                /* Slide scale/opacity (smoothstep falloff: 1.0 active,
                   0.68 / 0.5 fully off-center) + caption data-state
                   flip — same writer as the init paint. Caption flip
                   threshold = 0.9 so the cross-fade completes in sync
                   with the slide settling to center. */
                applyGalleryState(self.progress * lastIndex);
              },
            },
          }
        );

        /* Recompute initial/final positions on resize. ScrollTrigger's
           refresh recalculates the tween bounds via the function values
           above; we just need to re-park the track at its current x. */
        const onRefresh = (): void => {
          const st = tween.scrollTrigger;
          if (st) {
            /* Re-apply the from-value at progress 0 instead of leaving
               the cached transform from before resize. */
            const targetX = gsap.utils.interpolate(initialX(), finalX(), st.progress);
            gsap.set(track, { x: targetX });
          }
        };
        ScrollTrigger.addEventListener("refresh", onRefresh);
      }
    }
  }

  /* No manual gsap.ticker.sleep on axion:idle here:
     ScrollTrigger animations are inherently scroll-driven — they sit at
     rest unless the user scrolls. Sleeping the ticker would also freeze
     ST.update calls, which silently breaks the horizontal gallery the
     moment the page goes idle in the background. GSAP already pauses
     itself when the tab is fully hidden via Page Visibility API. */
</script>
