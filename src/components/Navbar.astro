  .navbar__chat-chip {
    border: 0;
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-fg);
    padding-block: 0.375rem;
    padding-inline: 0.625rem;
    /* Fully rounded pill — matches the Send button below and the
       overall liquid-pill language. Previously var(--radius-sm) (4px)
       which read as a tile, not a chip. */
    border-radius: 999px;
    /* Same top/bottom specular rim recipe as the liquid buttons, but
       applied directly (chips don't use the multi-layer .liquid stack
       since they're tiny and don't need a real displacement filter
       at this scale). */
    box-shadow:
      inset 0 1px 1px -0.5px rgba(255, 255, 255, 0.32),
