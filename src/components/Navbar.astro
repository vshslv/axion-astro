---
/**
 * Navbar.astro — persistent floating central navigation (Figma node 778:22064)
 *
 * Architecture — TWO nested rounded surfaces (not one morphing container):
 *   - .navbar__panel  — outer frame, 290 wide, rounded 34px. Block-size
 *                         animates between pill+gutters (closed) and the
 *                         full viewport (open). Dark translucent surface;
 *                         intentionally no backdrop-filter on this layer so
 *                         the inner pill's liquid-glass filter sees the real
 *                         document backdrop, not the panel's pre-blurred
 *                         output (Chrome's nested backdrop-filter rule).
 *   - .navbar__pill     — inner pill, 270×50, rounded 30px. Always visible.
 *                         Full liquid-glass recipe (1:1 with the Header CTA).
 *                         The whole pill is a <button> that toggles the panel.
 *
 * Open/close model:
 *   - Hover-capable devices (desktop): mouseenter on panel → open,
 *     mouseleave → close after a ~180 ms grace window.
 *   - Touch devices: click on the pill toggles.
 *   - Always: Escape closes when open; click outside closes when open;
 *     keyboard focus on the pill button + Enter/Space activates the click.
 *
 * Burger morph: lines just SPREAD APART on open (translateY ±3px). No X
 * transform — the spread reads as "the menu opens out from the centre",
 * thematically matching the panel expanding downward.
 *
 * Centered logo: grid-template-columns: 1fr auto 1fr — empty left cell
 * mirrors the burger's right cell, leaving the wordmark dead-centre.
 *
 * Sphere: dynamic-imported from src/three/sphere.ts on first open. Three.js
 * sphere2.0 (vshslv/sphere2.0) drives state on chat events 1:1 with the
 * source demo — input focus → listening, submit → thinking → speaking →
 * streamed reply (per-word speakPulse, tail eases toward normal) → normal.
 *
 * Assets:
 *   src/assets/axion-wordmark.svg — Axion wordmark, inlined via ?raw.
 *
 * Typography flagged: Figma uses ABC Diatype Plus Variable (unlicensed) —
 * substituted with Geist Variable per @theme + CLAUDE.md figma workflow.
 *
 * Copy preserved literally on first pass (Rule #6 — flagged, not silently
 * fixed): "I'm you personal assistant and I wil be guiding" — likely
 * typos ("your", "will").
 */
import axionWordmark from "../assets/axion-wordmark.svg?raw";

const links = [
  { label: "About Axion", href: "#about" },
  { label: "Features", href: "#features" },
  { label: "SPAR Framework", href: "#spar" },
  { label: "FAQ", href: "#faq" },
  { label: "Request a briefing", href: "#briefing" },
];

const chips = ["Start project", "Show all works", "What the Datum?"];
---

{/* Full-viewport dim + soft blur behind the navbar when open. Lighter than
    the video modal's backdrop (rgba 0.3 + blur 10px vs modal's 0.55 + 24px).
    JS toggles data-state on this element in sync with the panel. */}
<div class="navbar-backdrop" aria-hidden="true" data-state="closed"></div>

<nav class="navbar" aria-label="Main navigation">
  <div class="navbar__panel" data-state="closed">
    {/* The pill IS the toggle button. Whole pill clickable.
        The visual wordmark and burger are decorative inside the button. */}
    <button
      class="navbar__pill liquid"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="navbar-body"
    >
      <div class="liquid__filter" aria-hidden="true"></div>
      <div class="liquid__overlay" aria-hidden="true"></div>
      <div class="liquid__specular" aria-hidden="true"></div>
      <div class="liquid__content navbar__pill-inner">
        {/* Empty spacer mirrors the burger's column so the logo lands centre */}
        <span class="navbar__pill-spacer" aria-hidden="true"></span>
        <span class="navbar__logo" aria-hidden="true" set:html={axionWordmark} />
        {/* Burger as two HTML lines (not SVG paths) — Chrome reliably honours
            CSS transform on block elements; SVG path transforms via transform-box
            have flaky cross-browser support. Flex column + justify-content:
            space-between sets the resting 6px center-to-center gap. */}
        <span class="navbar__burger" aria-hidden="true">
          <span class="navbar__burger-line navbar__burger-line--top"></span>
          <span class="navbar__burger-line navbar__burger-line--bottom"></span>
        </span>
      </div>
    </button>

    <div class="navbar__body" id="navbar-body" inert>
      <section class="navbar__menu" aria-label="Sections">
        {/* "Up" — clickable scroll-to-top anchor. Closes the menu and
            smooth-scrolls the page to scrollY 0 via Lenis. Rendered as
            <button> rather than <a href="#top"> because the action is
            stateful (close panel + scroll), not a URL navigation, and
            we want focus/keyboard semantics, not history. */}
        <button class="navbar__label navbar__label--btn" type="button" data-scroll-top>
          Up
        </button>
        <ul class="navbar__links">
          {/* Group of links — no per-item mask swap; the focus-on-hover
              effect (others fade + blur) is the group-level affordance. */}
          {links.map((link) => (
            <li>
              <a class="navbar__link" href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </section>

      <section class="navbar__assistant" aria-label="AI assistant">
        <div class="navbar__sphere" aria-hidden="true">
          {/* Three.js sphere mounts here on first open via dynamic import.
              The placeholder fades the moment the canvas paints its first frame. */}
          <div class="navbar__sphere-canvas"></div>
          <div class="navbar__sphere-placeholder"></div>
        </div>
        <p class="navbar__assistant-title">Ask anything</p>

        <div class="navbar__chat">
          <div class="navbar__chat-messages" role="log" aria-live="polite">
            <p class="navbar__chat-msg navbar__chat-msg--bot navbar__chat-intro">
              Hello stranger and welcome! I&rsquo;m you personal assistant and I wil
              be guiding you through your journey.
            </p>
          </div>
          <div class="navbar__chat-chips">
            {/* Group of chips — no per-item mask; neighbour fade-blur on hover. */}
            {chips.map((chip) => (
              <button class="navbar__chat-chip" type="button" data-chip={chip}>{chip}</button>
            ))}
          </div>
          <form class="navbar__chat-form">
            <span class="navbar__chat-icon" aria-hidden="true">
              <svg viewBox="0 0 10 10" fill="none">
                <path
                  fill="currentColor"
                  fill-rule="evenodd"
                  clip-rule="evenodd"
                  d="M4.84971 1C2.72357 1 1 2.72357 1 4.8497C1 6.97582 2.72357 8.69939 4.84971 8.69939C5.74403 8.69939 6.56713 8.39444 7.22069 7.88284L9.20072 9.86287C9.38357 10.0457 9.68002 10.0457 9.86287 9.86287C10.0457 9.68002 10.0457 9.38357 9.86287 9.20072L7.88284 7.2207C8.39445 6.56714 8.69942 5.74403 8.69942 4.8497C8.69942 2.72357 6.97585 1 4.84971 1ZM1.93642 4.8497C1.93642 3.24073 3.24074 1.93641 4.84971 1.93641C6.45868 1.93641 7.763 3.24073 7.763 4.8497C7.763 6.45866 6.45868 7.76298 4.84971 7.76298C3.24074 7.76298 1.93642 6.45866 1.93642 4.8497Z"
                />
              </svg>
            </span>
            <input
              class="navbar__chat-input"
              type="text"
              placeholder="Ask anything"
              aria-label="Ask anything"
              autocomplete="off"
            />
            <button class="navbar__chat-send" type="submit" aria-label="Send">
              <span class="navbar__chat-send-mask">
                <span class="navbar__chat-send-text" data-text="default">Send</span>
                <span class="navbar__chat-send-text" data-text="hover" aria-hidden="true">Send</span>
              </span>
            </button>
          </form>
        </div>
      </section>

      <footer class="navbar__footer">
        {/* Footer pair — group; no per-item mask; neighbour fade-blur on hover. */}
        <a
          class="navbar__footer-link"
          href="https://www.linkedin.com/"
          target="_blank"
          rel="noreferrer"
        >Linkedin</a>
        {/* Email is an <a> with mailto fallback so the link still works if JS
            fails. The click handler in the script below preventDefaults and
            copies to the clipboard instead, briefly swapping the label to a
            centred "Copy" — explicitly NO hover swap (per design: the email
            is the one footer item that doesn't participate in the standard
            text-swap / neighbour fade-blur hover language). */}
        <a
          class="navbar__footer-email"
          href="mailto:info@thedatum.ai"
          data-email="info@thedatum.ai"
          aria-label="Copy email info@thedatum.ai"
        >
          <span class="navbar__footer-email-mask">
            <span class="navbar__footer-email-text" data-text="default">info@thedatum.ai</span>
            <span class="navbar__footer-email-text" data-text="copied" aria-hidden="true">Copy</span>
          </span>
        </a>
      </footer>
    </div>
  </div>
</nav>

<style>
  /* =================================================================
     BACKDROP — full-viewport dim + soft blur when the nav is open.
     Sits at z:99 (below the navbar wrapper at z:100) so it covers hero
     content but not the panel itself. Lighter than the modal backdrop
     by design — the navbar is a disclosure, not a modal.
     ================================================================= */
  .navbar-backdrop {
    position: fixed;
    inset: 0;
    z-index: 99;
    opacity: 0;
    pointer-events: none;
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(10px) saturate(120%);
    -webkit-backdrop-filter: blur(10px) saturate(120%);
    transition: opacity var(--dur-morph-fast) var(--ease-morph);
  }
  .navbar-backdrop[data-state="open"] {
    opacity: 1;
    pointer-events: auto;            /* catch clicks so they close the menu */
    transition: opacity var(--dur-morph) var(--ease-morph);
  }

  /* =================================================================
     FIXED WRAPPER — viewport-anchored UI (Rule #8 allowlist, approved).
     Spans the FULL viewport (inset: 0) so the inner panel can grow up to
     the available height. The 10px top gutter lives on padding-block-start
     instead of an inset offset — that keeps the wrapper a proper viewport-
     sized flex container so the panel isn't squeezed into its closed-state
     content height when it tries to expand. flex-start prevents stretch on
     the cross axis. pointer-events:none lets clicks pass through the
     invisible flanks; panel restores pointer-events:auto.
     ================================================================= */
  .navbar {
    position: fixed;
    inset: 0;
    z-index: 100;
    pointer-events: none;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-block-start: 0.625rem;        /* 10px top gutter */
  }

  /* =================================================================
     PLASHKA — outer frame, 290 wide, padding 10px.
     Block-size morphs between pill-tight (closed) and full viewport (open).
     Uses the canonical Axion glass treatment (27.5px backdrop blur, dark
     translucent surface). The inner pill is nested inside it — Chrome
     composites the pill's own backdrop-filter on top of the panel's
     blurred output, which still reads as glass-on-glass (just with the
     SVG distortion applied to the already-blurred page).
     ================================================================= */
  .navbar__panel {
    pointer-events: auto;
    /* `relative` so ::before below can position absolutely within the
       panel (the invisible safe-zone halo). */
    position: relative;
    display: flex;
    flex-direction: column;
    /* `--navbar-w-default` and `--navbar-w-open` drive a width morph on touch
       devices (the JS sets style.width via GSAP). Desktop never tweens width —
       it stays at the default through the entire open/close cycle. */
    --navbar-w-default: 18.125rem;          /* 290px */
    inline-size: var(--navbar-w-default);
    max-inline-size: calc(100vw - 1.25rem);
    /* Closed height = pill (50) + padding (10×2) + border (1×2) = 72px.
       The +2px accounts for the 1px panel border under box-sizing: border-box,
       which previously ate the bottom padding and left the pill visually
       offset upward (≈11px top gutter, ≈9px bottom). */
    block-size: 4.5rem;                   /* 72px */
    padding: 0.625rem;                    /* 10px all sides */
    /* Closed-state: panel itself is transparent. A filled background
       here (even without blur) would sit between the pill and the
       page, so pill's backdrop-filter url(#lg-dist) would refract a
       uniform surface and the liquid effect would collapse to a flat
       tint. The dark "frame" around the pill is drawn by a box-shadow
       on the pill itself (see .navbar__pill below) — that paints in
       the panel's 10px padding ring without blocking the area under
       the pill. */
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-panel);   /* 34px */
    /* No block-size in this transition list. The open/close timelines
       (animateOpen/animateClose in the script) tween panel height with
       their own multi-stage curve (stage 1 → hold → stage 2). If we
       leave block-size in here, every GSAP height write triggers a
       CSS transition over var(--dur-morph-fast) on top, which smears
       the hold between stages — the two-step motion collapses to one
       continuous slide. Other props (background / border / backdrop)
       are not GSAP-managed, so they keep their CSS transitions. */
    transition:
      background var(--dur-morph-fast) var(--ease-morph),
      border-color var(--dur-morph-fast) var(--ease-morph),
      backdrop-filter var(--dur-morph-fast) var(--ease-morph),
      transform var(--dur-morph) var(--ease-morph),
      opacity var(--dur-morph) var(--ease-morph);
  }

  /* Invisible safe-zone halo — extends the panel's hit-test area by
     16px in every direction. mouseleave on .navbar__panel only fires
     when the cursor exits THIS expanded boundary, so a small overshoot
     past the visible panel edge keeps the menu open without any
     pointer-position-tracking JS. Desktop-only (touch has no hover);
     only present while the panel is open (no point catching pointers
     near a closed pill — and a halo around the closed pill would
     intercept clicks on adjacent UI). */
  @media (hover: hover) and (pointer: fine) {
    .navbar__panel[data-state="open"]::before {
      content: "";
      position: absolute;
      inset: -16px;
      border-radius: inherit;
      pointer-events: auto;
      /* No visible paint — just a hit-test region. z-index keeps it
         behind the panel content so it never steals clicks from links. */
      z-index: -1;
    }
  }

  /* Open state — light glass per Figma (node 771:13844):
     bg = rgba(255,255,255,0.1), backdrop-blur 27.5px, NO border.
     Was previously dark glass + 1px white border, which deviated from
     the design. */
  .navbar__panel[data-state="open"] {
    background: var(--color-glass);       /* rgba(255,255,255,0.1) */
    backdrop-filter: blur(27.5px);        /* 27.5px — brand canon */
    -webkit-backdrop-filter: blur(27.5px);
    /* border stays transparent (declared on the base rule above) */
  }

  /* Footer hand-off — while the footer owns the screen the floating pill slides
     up out of view (the footer carries its own nav), then eases back on
     scroll-up. `data-hidden` on .navbar is toggled by a ScrollTrigger in
     Footer.astro; the slide + fade live here. Reduced-motion (below) snaps it
     instantly via `transition: none`, so the hide still works without motion. */
  .navbar[data-hidden] .navbar__panel {
    transform: translateY(-150%);
    opacity: 0;
    pointer-events: none;
  }

  /* The open-state morph (and the corresponding sections reveal) is driven
     imperatively by GSAP in the script below — orchestrated timelines stay
     in JS per the project convention (CSS first for trivial transitions /
     hover, GSAP for sequenced animations). Panel block-size + the menu /
     assistant / footer opacity are all set inline by the timeline. */

  /* =================================================================
     PILL — the always-visible interactive surface.
     Full liquid-glass recipe, identical to .hero__cta-top.
     The whole button area is clickable + drives the open/close action.
     ================================================================= */
  .navbar__pill {
    flex-shrink: 0;
    inline-size: 100%;                    /* fills panel inner = 270px */
    block-size: 3.125rem;                 /* 50px */
    border: 0;
    padding: 0;
    /* 12% white base — gives the pill enough body to stay distinct
       both against the page (dark hero) AND against the open-state
       panel (10% white glass). Combined with the liquid overlay (10%
       on top) the effective tint reads around 22%, matching the
       Figma pill which is clearly brighter than the surrounding
       light-glass panel. */
    background: rgba(255, 255, 255, 0.12);
    /* Dark "frame" ring painted in the panel's 10px padding area via
       box-shadow with 10px spread. Sits OUTSIDE the pill so backdrop
       under the pill stays untouched (so pill's liquid displacement
       still refracts the real page). Inset specular highlights live
       on .liquid__specular (z-index 2, above the displacement filter)
       so they aren't smeared by the url(#lg-dist) backdrop-filter —
       see override at the bottom of this file.
       Spread in rem (0.625rem = 10px at design baseline) so the ring
       scales with the rest of the pill on 4K — at 2× design font-size,
       it becomes 20px, matching the now-doubled panel padding. */
    box-shadow: 0 0 0 0.625rem rgba(0, 0, 0, 0.22);
    border-radius: var(--radius-pill);    /* 30px */
    color: var(--color-fg);
    cursor: pointer;
    font-family: inherit;
    overflow: hidden;
    /* user-select: none — button text is non-selectable per Buttons convention */
    user-select: none;
    -webkit-user-select: none;
    transition:
      transform 0.2s ease,
      box-shadow var(--dur-morph-fast) var(--ease-morph);
  }

  /* Open state — drop the outer dark frame (panel's own dark glass
     now provides the framing). Specular highlights live on
     .liquid__specular and aren't affected by this rule. */
  .navbar__panel[data-state="open"] .navbar__pill {
    box-shadow: none;
  }
  .navbar__pill:active {
    transform: scale(0.99);
  }
  .navbar__pill:focus-visible {
    outline: 2px solid var(--color-fg);
    outline-offset: 4px;
  }

  /* Liquid glass recipe (.liquid stack) lives in src/styles/global.css.
     The SVG filter defs #lg-dist / #lg-dist-sm referenced by .liquid__filter
     are defined inside Header.astro and shared across pages. */

  /* =================================================================
     PILL INNER — grid keeps the logo dead-centre between two equal cells.
     Layout: [ spacer 1fr | logo auto | burger 1fr ]
     ================================================================= */
  .navbar__pill-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding-inline: var(--space-sm);
    block-size: 100%;
  }

  .navbar__pill-spacer {
    /* deliberately empty — mirrors the burger column so the logo centres */
  }

  .navbar__logo {
    justify-self: center;
    inline-size: 4.4375rem;               /* 71px ≈ Figma 71.1 wordmark width */
    block-size: 1.3125rem;                /* 21px ≈ Figma 20.6 wordmark height */
    line-height: 0;
    display: inline-block;
  }

  /* Burger: 20×7 box, two 1px horizontal lines top/bottom, gap between
     centres = 6. Open state grows the burger to 13px tall; the flex parent's
     justify-content: space-between pushes the lines to the new edges →
     centre-to-centre gap becomes 12 (1:1 with the spec). Animating the
     PARENT's block-size is simpler and more reliable than animating each
     child's transform (which had paint-quirks on SVG paths AND on flex
     children in this stack).
     The block-size resting value lives here as a fallback for the brief
     moment before the script hydrates; once GSAP runs, the open/close
     timeline drives `style.height` inline in two stages synced with the
     panel morph (stage 1 → 10px / stage 2 → 13px), so the burger reads as
     one motion with the panel. The CSS transition is intentionally absent —
     all motion is GSAP-orchestrated to keep stage timings 1:1. */
  .navbar__burger {
    justify-self: end;
    inline-size: 1.25rem;                 /* 20px */
    block-size: 0.4375rem;                /* 7px → 6px centre-gap (resting) */
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .navbar__burger-line {
    display: block;
    inline-size: 100%;
    block-size: 1px;
    background: currentColor;
    flex-shrink: 0;
  }

  /* =================================================================
     BODY — hidden when closed, fades + slides in when open.
     padding-block-start = the 10px gap between pill bottom and "Up" label.
     ================================================================= */
  .navbar__body {
    flex: 1 1 auto;
    min-block-size: 0;
    overflow-y: auto;
    overflow-x: hidden;
    display: flex;
    flex-direction: column;
    padding-block-start: var(--space-md);
    padding-block-end: 0;
    opacity: 0;
    pointer-events: none;
    /* Body itself doesn't transition — individual sections own their fade
       timings so they can stagger with the staged panel animation. */
  }
  .navbar__panel[data-state="open"] .navbar__body {
    opacity: 1;
    pointer-events: auto;
  }

  /* =================================================================
     MENU SECTION — "Up" + 5 links + divider
     ================================================================= */
  .navbar__menu {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    /* opacity + translateY animated imperatively by the GSAP open/close
       timeline. The element starts hidden via inline-style set by the
       script on first mount. */
  }

  .navbar__label {
    margin: 0;
    font-size: var(--text-sm);
    line-height: 1.4;
    color: var(--color-fg);
    opacity: 0.2;
    letter-spacing: -0.03em;
  }

  /* When rendered as a button (the "Up" scroll-to-top trigger) — strip
     UA defaults and add hover affordance. The opacity ramp signals that
     the previously-static label is interactive. */
  .navbar__label--btn {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 0;
    font-family: inherit;
    text-align: start;
    cursor: pointer;
    user-select: none;
    -webkit-user-select: none;
    transition: opacity var(--dur-hover) var(--ease-out-soft);
  }
  @media (hover: hover) {
    .navbar__label--btn:hover {
      opacity: 0.6;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .navbar__label--btn {
      transition: none;
    }
  }

  .navbar__links {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    /* No gap — the row spacing lives inside each link as padding-block so the
       full row (including former gap) is hover-active. With gap, the empty
       strip between items dropped the :hover, blanking the fade-blur effect
       mid-cursor-travel. Padding-block: 0.3125rem on each link reproduces the
       previous 10px visual rhythm (5px above + 5px below = 10px between
       baselines) while making every pixel of the list a hover target. */
    gap: 0;
  }

  .navbar__link {
    color: var(--color-fg);
    text-decoration: none;
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    letter-spacing: -0.03em;
    display: block;                       /* full-row hover target */
    padding-block: 0.3125rem;             /* 5px top + 5px bottom = 10px rhythm */
    user-select: none;
    -webkit-user-drag: none;
    /* Focus-on-hover: when another link is hovered (see :has rule below), this
       one fades + blurs. The transitions share the canonical hover tokens so
       it reads as part of the same motion language as the mask text swap. */
    transition:
      opacity var(--dur-hover) var(--ease-out-soft),
      filter var(--dur-hover) var(--ease-out-soft);
  }
  /* When the user hovers any link, the others fade to 40% and blur slightly.
     Desktop-only — touch devices skip this so tap targets stay legible. */
  @media (hover: hover) {
    .navbar__links:has(.navbar__link:hover) .navbar__link:not(:hover) {
      opacity: 0.4;
      filter: blur(2px);
    }
  }

  /* =================================================================
     ASSISTANT SECTION — sphere + Ask anything + chat card.
     margin-block-start: auto pushes assistant + footer to bottom of body.
     ================================================================= */
  .navbar__assistant {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2xs);
    margin-block-start: auto;
    /* opacity + translateY animated by the GSAP timeline (reveals AFTER
       the panel has finished opening — see script). */
  }

  .navbar__sphere {
    position: relative;
    /* Figma spec is 99×100 but at that size the bloom halo dissolves the
       shell detail (the 100px canvas is barely bigger than the orb itself).
       Bumped to 120×120 so the orb dominates the widget without bloom mush. */
    inline-size: 7.5rem;                  /* 120px */
    block-size: 7.5rem;                   /* 120px */
    border-radius: 50%;
    overflow: hidden;
    /* Warm radial wash sits BEHIND the canvas to fill the orb's interior
       so it doesn't read as a "black hole" against the translucent panel.
       Centred slightly above middle to match the orb's perceived weight. */
    background: radial-gradient(
      circle at 50% 45%,
      rgba(255, 195, 130, 0.16) 0%,
      rgba(255, 165, 90, 0.08) 35%,
      transparent 70%
    );
    /* plus-lighter so the orb (and the warm wash) composite additively over
       the panel glass — brightens the area without flattening contrast. */
    mix-blend-mode: plus-lighter;
    transition:
      inline-size var(--dur-morph-fast) var(--ease-morph),
      block-size var(--dur-morph-fast) var(--ease-morph);
  }
  @media (prefers-reduced-motion: reduce) {
