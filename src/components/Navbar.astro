  .navbar__chat-send-mask {
    display: inline-grid;
    grid-template-areas: "stack";
    overflow: hidden;
    vertical-align: bottom;
    block-size: calc(0.5625rem * var(--leading-snug));
    /* Optical correction: shift the mask up by 1px so the cap-line of "Send"
       sits visually centred against the magnifier icon and pill body. At 9px
       font-size the line-box descender slot drags the glyphs down a hair too
       far without this nudge. */
    transform: translateY(-1px);
  }
  .navbar__chat-send-text {
    grid-area: stack;
    white-space: nowrap;
    transition: transform var(--dur-hover) var(--ease-out-soft);
  }
  .navbar__chat-send-text[data-text="default"] { transform: translateY(0); }
  .navbar__chat-send-text[data-text="hover"]   { transform: translateY(100%); }
  @media (hover: hover) {
    .navbar__chat-send:hover .navbar__chat-send-text[data-text="default"] { transform: translateY(-100%); }
    .navbar__chat-send:hover .navbar__chat-send-text[data-text="hover"]   { transform: translateY(0); }
  }

  /* =================================================================
     FOOTER — divider + Linkedin + email
     ================================================================= */
  .navbar__footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding-block-start: var(--space-sm);
    /* opacity + translateY animated by the GSAP timeline (revealed with
       the assistant after the panel has finished opening). */
  }
  .navbar__footer-link,
  .navbar__footer-email {
    color: var(--color-fg);
    text-decoration: none;
