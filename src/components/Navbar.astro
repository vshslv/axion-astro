  .navbar__footer-email-text[data-text="default"] { transform: translateY(0); }
  .navbar__footer-email-text[data-text="copied"]  {
    transform: translateY(100%);
    /* Centred so the "Copy" feedback sits visually balanced inside the mask
       box (which is sized to the longer "info@thedatum.ai" label). */
    text-align: center;
  }
  .navbar__footer-email[data-copied] .navbar__footer-email-text[data-text="default"] { transform: translateY(-100%); }
  .navbar__footer-email[data-copied] .navbar__footer-email-text[data-text="copied"]  { transform: translateY(0); }

  /* Footer pair — when LinkedIn is hovered, only the LinkedIn lifts; the
     email is intentionally excluded from the standard neighbour-fade-blur
     language because its only feedback is the click-driven "Copy" swap,
     and a hover-fade competing with that would muddle the affordance. */

  /* =================================================================
     MOBILE — virtual keyboard handling
     ================================================================= */
  @media (max-width: 40em) {
    /* Bump the chat input to 16px on mobile — iOS auto-zooms any input
       under 16px on focus, which makes the whole site visibly scale up.
       16px keeps the layout stable. The placeholder/value still reads as
       intended thanks to letter-spacing. */
    .navbar__chat-input {
      font-size: 1rem;                   /* 16px */
    }
  }
  /* (The [data-kb-open] .navbar__sphere shrink lives in <style is:global>
     below — Astro's scoped-style hashing would attach the cid to the
     ancestor part of the selector, but <html> doesn't carry the cid.) */

  /* =================================================================
     REDUCED MOTION
     ================================================================= */
  @media (prefers-reduced-motion: reduce) {
    .navbar__panel,
    .navbar__body,
    .navbar__menu,
    .navbar__assistant,
    .navbar__footer,
    .navbar__burger,
    .navbar__link,
    .navbar__chat-chip,
    .navbar__chat-send,
    .navbar__chat-send-text,
    .navbar__footer-link,
    .navbar__footer-email,
    .navbar__footer-email-text,
    .navbar__sphere-canvas {
      transition: none;
    }
    /* Skip the staged open keyframes — direct state switch. */
    .navbar__panel[data-state="open"] {
      animation: none;
    }
  }
</style>

<style is:global>
  /* Soft-keyboard sphere shrink. Marked is:global because the [data-kb-open]
     attribute lives on <html>, which sits outside this component's scope —
     Astro would otherwise hash the ancestor part of the selector and the
     rule would never match. */
  [data-kb-open] .navbar__sphere {
    inline-size: 4rem;                   /* 64px — shrunken so chat + sphere both fit */
    block-size: 4rem;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { CustomEase } from "gsap/CustomEase";
  import { initSphere, pickResponse, type SphereHandle, type SphereState } from "../three/sphere";

  gsap.registerPlugin(CustomEase);
  /* Mirrors --ease-out-soft from global.css so GSAP tweens read the same as CSS hover transitions. */
  CustomEase.create("axEaseOutSoft", "0.22, 1, 0.36, 1");

  /**
   * Disclosure pattern with two open mechanisms:
   *   - Click on .navbar__pill (always) — toggles open/closed.
   *   - Hover on .navbar__panel (desktop only) — opens on mouseenter,
   *     closes on mouseleave after a short grace window.
   *
   * Open visual is a GSAP timeline (per the orchestrations-on-GSAP rule):
   *   - Stage 1 (0–420ms): panel grows from 70 → 21rem (menu list height),
   *     menu fades in 100ms after start.
   *   - Hold (420–580ms): ~160ms pause — menu reads as a stop.
   *   - Stage 2 (580–1100ms): panel grows from 21rem → full height.
   *   - Chat reveal (~1150ms onward): assistant + footer fade in AFTER the
   *     panel settles, so the WebGL sphere mount + chat layout don't fight
   *     the still-animating block-size (was the source of perceived "lag").
   *   NOTE: the times above are 1× AUTHORING times. The whole open is played
   *   back at OPEN_TIME_SCALE× via timeline.timeScale(), so real on-screen
   *   durations are these divided by OPEN_TIME_SCALE (~20% snappier).
   *
   * Sphere init is also deferred to the chat-reveal beat so Three.js context
   * creation doesn't race the open animation.
   *
   * Close: faster, no stages — content fades, panel collapses, both in
   * parallel (~380ms).
   *
   * Escape + click-outside both close.
   */
  const panel = document.querySelector<HTMLDivElement>(".navbar__panel");
  const backdrop = document.querySelector<HTMLDivElement>(".navbar-backdrop");
  const pill = document.querySelector<HTMLButtonElement>(".navbar__pill");
  const body = document.querySelector<HTMLDivElement>(".navbar__body");
  const sphereContainer = document.querySelector<HTMLDivElement>(".navbar__sphere-canvas");
  const chatInput = document.querySelector<HTMLInputElement>(".navbar__chat-input");
  const chatForm = document.querySelector<HTMLFormElement>(".navbar__chat-form");
  const chatSend = document.querySelector<HTMLButtonElement>(".navbar__chat-send");
  const chatMessages = document.querySelector<HTMLDivElement>(".navbar__chat-messages");
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>(".navbar__chat-chip"));

  if (panel && pill && body) {
    const menuEl = panel.querySelector<HTMLElement>(".navbar__menu");
    const assistantEl = panel.querySelector<HTMLElement>(".navbar__assistant");
    const footerEl = panel.querySelector<HTMLElement>(".navbar__footer");

    /* Note: an earlier iteration tried to pop the sphere in with a scale +
       rotate reveal. Reverted on request — Three.js is sensitive to CSS
       transforms during initSphere() (it reads container size via
       getBoundingClientRect, which is transform-aware), and even post-mount
       transforms cluttered the assistant reveal. The sphere now simply fades
       in along with the rest of the assistant column via the existing CSS
       opacity transition on .navbar__sphere-canvas[data-ready]. */

    const isHoverDevice = window.matchMedia("(hover: hover) and (pointer: fine)").matches;
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isMobileViewport = () => window.matchMedia("(max-width: 40em)").matches;
    const HOVER_OUT_DELAY = 110; // ms grace window after mouseleave (snappier close)
    let hoverOutTimer: number | undefined;

    // ─── Open / close animation (GSAP) ────────────────────────────────
    // Stage-1 stop height is computed dynamically per-open so the bottom
    // gap below the last menu item visually matches the top gap between the
    // pill and the "Up" label. Both gaps = body padding-block-start, which
    // also tracks the fluid --space-md token across viewports.
    //
    //   stage1_panel = pill_block (72 = 50 + 10*2 padding + 1*2 border)
    //                + body_padding_block_start    ← top gap
    //                + menu_natural_height
    //                + body_padding_block_start    ← matching bottom gap
    //
    // The full open height = current dvh − 1.25rem (recomputed each open so
    // it tracks viewport changes / mobile keyboard via visualViewport.height).
    const CLOSED_PX = 4.5 * 16;       // 72 — closed panel height (50 pill + 10*2 padding + 1*2 border)
    const PILL_BLOCK_PX = 4.5 * 16;
    const stage1HeightPx = () => {
      if (!menuEl || !body) return 21 * 16; // fallback to previous 336px
      const cs = window.getComputedStyle(body);
      const padTop = parseFloat(cs.paddingBlockStart || "0") || 0;
      // scrollHeight reads the natural content height regardless of the
      // body's current constrained block-size, so we get the menu's true
      // laid-out height even when the panel is still closed.
      const menuH = menuEl.scrollHeight;
      return Math.round(PILL_BLOCK_PX + padTop * 2 + menuH);
    };
    const fullOpenPx = () => {
      const vp = window.visualViewport;
      const dvh = vp ? vp.height : window.innerHeight;
      return dvh - 20; // 1.25rem at 16px
    };

    // Burger spread — staged in lockstep with the panel morph.
    const burgerEl = panel.querySelector<HTMLElement>(".navbar__burger");
    const BURGER_CLOSED_PX = 7;      // 0.4375rem — 6px centre gap
    const BURGER_STAGE1_PX = 10;     // mid spread — feels like "halfway" alongside stage 1
    const BURGER_OPEN_PX = 13;       // 0.8125rem — 12px centre gap (final)

    // Mobile-only width morph: on touch viewports we widen the panel from its
    // 290px default to align with the page's global gutters BEFORE expanding
    // the height. The default panel inline-size matches the closed pill on
    // desktop, so desktop never triggers this morph (we test isMobileViewport).
    const DEFAULT_W_PX = 18.125 * 16; // 290 — matches CSS default
    const pagePaddingPx = () => {
      // Mirror the global token clamp(1rem, 7vw, 7.5rem) so the open-state
      // pill aligns with all other content gutters at the current viewport.
      return Math.min(Math.max(16, window.innerWidth * 0.07), 120);
    };
    const expandedWidthPx = () => Math.max(
      DEFAULT_W_PX,                                 // never narrower than default
      Math.min(window.innerWidth - 2 * pagePaddingPx(), window.innerWidth - 20),
    );

    // Initial hidden state for the body sections so the first open animates
    // from below. GSAP will set inline opacity/y; clearProps on close
    // restores these.
    if (menuEl) gsap.set(menuEl, { opacity: 0, y: -4 });
    if (assistantEl) gsap.set(assistantEl, { opacity: 0, y: -4 });
    if (footerEl) gsap.set(footerEl, { opacity: 0, y: -4 });

    let activeTl: gsap.core.Timeline | null = null;
    let sphereMountTimer: number | undefined;

    // Global playback multiplier for the OPEN choreography. >1 = snappier.
    // Applied via timeline.timeScale() so every beat (panel morph, the hold,
    // the burger spread, the staggered chat reveal) compresses by the SAME
    // factor — all the hand-tuned sync points stay locked, the open just
    // plays faster. (Close is already snappy by design and stays untouched.)
    const OPEN_TIME_SCALE = 1.2;

    const animateOpen = () => {
      activeTl?.kill();
      if (reducedMotion) {
        // Direct snap — no staged morph
        gsap.set(panel, { height: fullOpenPx() });
        gsap.set([menuEl, assistantEl, footerEl].filter(Boolean), { opacity: 1, y: 0 });
        if (burgerEl) gsap.set(burgerEl, { height: BURGER_OPEN_PX });
        return;
      }

      const mobile = isMobileViewport();
      const widthOffset = mobile ? 0.22 : 0; // mobile: width pre-expands first, then height stages run
      const tl = gsap.timeline();
      const stage1 = stage1HeightPx();

      // Stage 0 (mobile only): widen panel to match page gutters BEFORE the
      // vertical staged open. Desktop skips this and starts at 0 directly.
      if (mobile) {
        tl.to(panel, { width: expandedWidthPx(), duration: 0.26, ease: "power3.out" }, 0);
      }

      //   stage 1:           0 → 0.42 (panel CLOSED → stage1, soft expo.out)
      //   hold:           0.42 → 0.58 (~160 ms — menu reads as a stop)
      //   stage 2:        0.58 → 1.10 (panel stage1 → full)
      //   chat reveal:    1.15 → 1.55 (assistant + footer fade in)
      //   burger:        same two stages, tied to the panel curve so the
      //                  spread visibly pauses with the panel and finishes
      //                  alongside it (one motion, not two competing ones).
      tl
        .to(panel, { height: stage1, duration: 0.42, ease: "expo.out" }, widthOffset + 0)
        .to(menuEl, { opacity: 1, y: 0, duration: 0.4, ease: "power2.out" }, widthOffset + 0.1)
        .to(panel, { height: fullOpenPx, duration: 0.52, ease: "power3.out" }, widthOffset + 0.58)
        .to([assistantEl, footerEl].filter(Boolean) as HTMLElement[],
            { opacity: 1, y: 0, duration: 0.4, ease: "power2.out", stagger: 0.05 }, widthOffset + 1.15);

      if (burgerEl) {
        /* Two stages, NO hold between them. Stage1 ease-out gives the natural
           mid-spread "pause" optically, stage2 carries on immediately — reads
           as two-step but without a visible stutter. End time = 1.10s so the
           burger finishes in sync with the panel's stage 2. */
        tl.to(burgerEl, { height: BURGER_STAGE1_PX, duration: 0.42, ease: "axEaseOutSoft" }, widthOffset + 0)
          .to(burgerEl, { height: BURGER_OPEN_PX,   duration: 0.68, ease: "axEaseOutSoft" }, widthOffset + 0.42);
      }

      // Play the whole open ~20% faster while keeping every staged sync point
      // intact (durations + positions above are 1× authoring times).
      tl.timeScale(OPEN_TIME_SCALE);
      activeTl = tl;
    };

    const animateClose = () => {
      activeTl?.kill();
      window.clearTimeout(sphereMountTimer);
      if (reducedMotion) {
        gsap.set(panel, { clearProps: "height,width" });
        gsap.set([menuEl, assistantEl, footerEl].filter(Boolean), { opacity: 0, y: -4 });
        if (burgerEl) gsap.set(burgerEl, { clearProps: "height" });
        return;
      }

      const mobile = isMobileViewport();
      const tl = gsap.timeline();

      // Close is intentionally faster than open — snappy retreat reads as
      // confidence (open = welcoming, soft; close = decisive, quick). Burger
      // collapses in a single tween (no staged retreat) so the user gets an
      // immediate visual confirmation that the close was registered.
      tl
        .to([menuEl, assistantEl, footerEl].filter(Boolean) as HTMLElement[],
            { opacity: 0, y: -4, duration: 0.14, ease: "power2.in" }, 0)
        .to(panel, {
          height: CLOSED_PX,
          duration: 0.22,
          ease: "power3.in",
        }, 0);

      if (burgerEl) {
        tl.to(burgerEl, { height: BURGER_CLOSED_PX, duration: 0.34, ease: "axEaseOutSoft" }, 0);
      }

      // Mobile: shrink width back to default AFTER height has collapsed, so
      // the panel doesn't visibly reflow content while still tall.
      if (mobile) {
        tl.to(panel, {
          width: DEFAULT_W_PX,
          duration: 0.22,
          ease: "power3.inOut",
          onComplete: () => gsap.set(panel, { clearProps: "width,height" }),
        }, 0.18);
      } else {
        // Desktop: only height was tweened, clear it once close completes.
        tl.set(panel, { clearProps: "height" });
      }

      activeTl = tl;
    };

    const setState = (open: boolean) => {
      const next = open ? "open" : "closed";
      if (panel.dataset.state === next) return;
      panel.dataset.state = next;
      if (backdrop) backdrop.dataset.state = next;   // dim + soft blur of page behind
      pill.setAttribute("aria-expanded", String(open));
      pill.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      if (open) {
        body.removeAttribute("inert");
        animateOpen();
        /* Lock background scroll while the menu is open. Two-pronged:
           1. window.__lenis.stop() — stops the smooth-scroll RAF loop so
              wheel/trackpad input is ignored.
           2. html { overflow: hidden } — defends against native scroll
              gestures Lenis doesn't intercept (iOS touch flick, system
              scrollbars, dev-tools wheel). Inline style restored on close. */
        const w = window as Window & { __lenis?: { stop: () => void; start: () => void } };
        w.__lenis?.stop();
        document.documentElement.style.overflow = "hidden";
        // Defer sphere mount until the chat-reveal beat so the WebGL context
        // creation doesn't race the block-size animation (was visible as a
        // small stutter mid-open). 1100ms = panel's full settle time at 1×;
        // divided by OPEN_TIME_SCALE so it still lands on the now-earlier settle.
        window.clearTimeout(sphereMountTimer);
        sphereMountTimer = window.setTimeout(() => {
          if (panel.dataset.state === "open") mountSphere();
        }, reducedMotion ? 0 : Math.round(1100 / OPEN_TIME_SCALE));
        // If the sphere was mounted on a previous open and then paused on
        // close, wake it back up — but only if the tab is in the foreground;
        // otherwise we'd burn cycles on a hidden viewport.
        reconcileSphereRunning();
      } else {
        body.setAttribute("inert", "");
        // Closing — bring orb back to its calm baseline visually, then
        // park its rAF loop. WebGL state stays so the next open is instant.
        sphere?.setState("normal");
        animateClose();
        reconcileSphereRunning();
        /* Restore background scroll — mirror image of the open lock. */
        const w = window as Window & { __lenis?: { stop: () => void; start: () => void } };
        w.__lenis?.start();
        document.documentElement.style.overflow = "";
      }
    };

    // ─── Sphere mount (lazy, single-shot, skipped on reduced motion) ──
    let sphere: SphereHandle | null = null;
    let sphereLoading = false;

    /** Sphere should run iff: panel is open AND user isn't idle (idle =
     *  tab hidden, or 8s with no input — see the global tracker in
     *  BaseLayout.astro). Anywhere else, pause to free rAF + GPU. */
    const reconcileSphereRunning = () => {
      if (!sphere) return;
      const userPresent = !document.documentElement.hasAttribute("data-idle");
      const shouldRun = panel.dataset.state === "open" && userPresent;
      if (shouldRun) sphere.resume();
      else sphere.pause();
    };

    async function mountSphere() {
      if (sphere || sphereLoading || !sphereContainer) return;
      if (reducedMotion) return; // placeholder stays
      sphereLoading = true;
      try {
        // Tuned for the 120px sphere container against the translucent panel.
        // The original sphere2.0 demo lives on a fully black backdrop; here the
        // panel is lighter, so the orb's interior risked reading as a black
        // void. Slightly hotter bloom (0.8 vs 0.65) + wider radius (0.5 vs 0.4)
        // fills the interior while still letting individual shell particles
        // read at this size.
        sphere = initSphere(sphereContainer, { bloomScale: 0.8, bloomRadius: 0.5 });
        sphereContainer.setAttribute("data-ready", "");
        // Edge case: tab went hidden during the 1100ms mount delay, or the
        // user closed the navbar before mount completed. Pause immediately
        // in those cases — reconcile reads the live conditions.
        reconcileSphereRunning();
      } catch (err) {
        // Placeholder remains visible — never blank the UI
        console.warn("Sphere init failed, keeping placeholder", err);
      } finally {
        sphereLoading = false;
      }
    }

    // Pause the sphere whenever the user steps away — driven by the global
    // tracker in BaseLayout.astro (`axion:idle` / `axion:active`). Covers
    // both tab-hidden AND foreground-but-idle (8s no input). Browsers only
    // throttle rAF to ~1 Hz on hidden tabs and don't pause it at all when
    // the tab is foreground-but-unfocused, so killing the loop ourselves
    // is the only reliable saver. Cheap: no WebGL teardown, just rAF off.
    document.addEventListener("axion:idle", reconcileSphereRunning);
    document.addEventListener("axion:active", reconcileSphereRunning);

    /* ─── Sphere "watches" cursor across the whole panel ────────────────
       The sphere internally also listens to pointermove on its own canvas,
       but that's a ~99px area — the user barely sees a reaction unless
       hovering directly on the orb. While the menu is OPEN we widen the
       watch area to the entire panel: any pointermove inside the panel
       normalizes against the sphere's centre and feeds sphere.aim().
       Only active when sphere is mounted and panel is open. Pointerleave
       on the panel resets aim to (0,0) so the orb returns to centre. */
    const sphereWatchHandler = (e: PointerEvent) => {
      if (!sphere || panel.dataset.state !== "open" || !sphereContainer) return;
      const sphereRect = sphereContainer.getBoundingClientRect();
      const cx = sphereRect.left + sphereRect.width / 2;
      const cy = sphereRect.top + sphereRect.height / 2;
      const dx = e.clientX - cx;
      const dy = e.clientY - cy;
      /* Normalize by the panel half-extents so cursor in the panel
         corners hits ±1 (full tilt). Capping at the panel boundary
         keeps the response proportional to a sensible "reach". */
      const panelRect = panel.getBoundingClientRect();
      const nx = Math.max(-1, Math.min(1, dx / (panelRect.width / 2)));
      const ny = Math.max(-1, Math.min(1, dy / (panelRect.height / 2)));
      sphere.aim(nx, ny);
    };
    const sphereWatchLeave = () => {
      sphere?.aim(0, 0);
    };
    panel.addEventListener("pointermove", sphereWatchHandler, { passive: true });
    panel.addEventListener("pointerleave", sphereWatchLeave, { passive: true });

    // ─── Click on pill — always toggles ───────────────────────────────
    pill.addEventListener("click", () => {
      setState(panel.dataset.state !== "open");
    });

    // ─── Top/bottom anchor button — label switches with scroll position
    /* Per user spec: label "Up" when the user is near the first
       section, "Down" when in the footer area, "Up" (default) in the
       middle. Click always navigates to the OPPOSITE edge so the
       button always takes the user somewhere useful:
          near top    → label "Up",   click → bottom of page
          near footer → label "Down", click → top of page
          middle      → label "Up",   click → top
       Thresholds = 30% of viewport from each edge. */
    const scrollTopBtn = panel.querySelector<HTMLButtonElement>("[data-scroll-top]");
    if (scrollTopBtn) {
      const updateAnchorLabel = (): void => {
        const scrollY = window.scrollY;
        const vh = window.innerHeight;
        const maxScroll = Math.max(0, document.documentElement.scrollHeight - vh);
        const edge = vh * 0.3;
        if (scrollY < edge) {
          scrollTopBtn.textContent = "Up";
          scrollTopBtn.dataset.scrollTarget = "bottom";
        } else if (scrollY > maxScroll - edge) {
          scrollTopBtn.textContent = "Down";
          scrollTopBtn.dataset.scrollTarget = "top";
        } else {
          scrollTopBtn.textContent = "Up";
          scrollTopBtn.dataset.scrollTarget = "top";
        }
      };

      /* Initial sync + listen to scroll/resize. window's `scroll` event
         covers both native AND Lenis (Lenis writes document.scrollTop
         which fires the event). */
      updateAnchorLabel();
      window.addEventListener("scroll", updateAnchorLabel, { passive: true });
      window.addEventListener("resize", updateAnchorLabel);

      scrollTopBtn.addEventListener("click", () => {
        const w = window as Window & {
          __lenis?: { scrollTo: (target: number, opts?: object) => void };
        };
        const target =
          scrollTopBtn.dataset.scrollTarget === "bottom"
            ? document.documentElement.scrollHeight
            : 0;
        setState(false);
        /* Defer the scroll one frame so the close animation has a
           chance to start (avoids a visual collision where the closing
           panel and the scrolling page move simultaneously). Falls
           back to native scrollTo if Lenis isn't around (reduced-
           motion path). */
        window.setTimeout(() => {
          if (w.__lenis) {
            w.__lenis.scrollTo(target, { duration: 1.0 });
          } else {
            window.scrollTo({ top: target, behavior: "smooth" });
          }
        }, 50);
      });
    }

    // ─── Section anchor links — close menu, then smooth-scroll ─────────
    /* The menu's section links are plain in-page #anchors. Letting the
       browser handle them natively causes two problems: the hash jump
       fights Lenis' smooth scroll, and on hover-to-open desktop the panel
       stays open (the cursor is still inside it) so the backdrop blur
       lingers over the very section the user just jumped to. So we
       intercept: close the panel first — which restores Lenis + page
       scroll and drops the backdrop — then defer the smooth scroll one
       beat so the close leads. Mirrors the data-scroll-top handler above,
       and covers both desktop (collapse + un-blur) and mobile (navigate
       to the section, then collapse) in one path. */
    const sectionLinks = panel.querySelectorAll<HTMLAnchorElement>(".navbar__link");
    sectionLinks.forEach((link) => {
      link.addEventListener("click", (event) => {
        const href = link.getAttribute("href") ?? "";
        if (!href.startsWith("#") || href.length < 2) return; // not an in-page anchor
        // Intercept so the native jump never races Lenis and the panel
        // always closes — even for a dangling anchor like #briefing (no
        // section yet); at minimum the menu + backdrop blur must clear.
        event.preventDefault();
        const targetEl = document.getElementById(href.slice(1));
        setState(false);
        if (!targetEl) return; // nothing to scroll to — closing is enough
        // Keep the URL in sync without a native jump (replaceState, not
        // pushState: a hash-only history entry would let the back button
        // change the URL without scrolling under Lenis — confusing).
        history.replaceState(null, "", href);
        const w = window as Window & {
          __lenis?: { scrollTo: (t: HTMLElement, opts?: object) => void };
        };
        window.setTimeout(() => {
          if (w.__lenis) {
            w.__lenis.scrollTo(targetEl, { duration: 1.0 });
          } else {
            // Reduced-motion path: Lenis isn't initialised. Honour the
            // user's motion preference rather than forcing a smooth scroll.
            targetEl.scrollIntoView({ behavior: reducedMotion ? "auto" : "smooth", block: "start" });
          }
        }, 50);
      });
    });

    // ─── Desktop hover-to-open ────────────────────────────────────────
    /* Safe zone is implemented in CSS via .navbar__panel::before — an
       invisible 16px ring that's part of the panel's hit-test area.
       mouseleave only fires once the cursor crosses the extended
       boundary, so a single HOVER_OUT_DELAY is enough; no JS pointer
       tracking, no dual-delay flicker on re-entry. */
    if (isHoverDevice) {
      panel.addEventListener("mouseenter", () => {
        window.clearTimeout(hoverOutTimer);
        setState(true);
      });
      panel.addEventListener("mouseleave", () => {
        window.clearTimeout(hoverOutTimer);
        hoverOutTimer = window.setTimeout(() => setState(false), HOVER_OUT_DELAY);
      });
    }

    // ─── Escape closes ────────────────────────────────────────────────
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && panel.dataset.state === "open") {
        setState(false);
        pill.focus();
      }
    });

    // ─── Click outside closes ─────────────────────────────────────────
    document.addEventListener("click", (event) => {
      if (panel.dataset.state !== "open") return;
      if (!(event.target instanceof Node)) return;
      if (!panel.contains(event.target)) setState(false);
    });

    // ─── Email — click copies to clipboard, swaps label to "Copied" ────
    // Anchor preserves the mailto: fallback for no-JS / clipboard-blocked
    // contexts; the click handler below upgrades the action to a copy.
    const emailLink = panel.querySelector<HTMLAnchorElement>(".navbar__footer-email");
    if (emailLink) {
      let copiedTimer: number | undefined;
      emailLink.addEventListener("click", (event) => {
        // Must preventDefault SYNCHRONOUSLY, before any await — otherwise the
        // browser races us and follows the mailto: href while we're still
        // resolving the clipboard promise (event.preventDefault is a no-op
        // once the event has been dispatched past the current task).
        event.preventDefault();
        const email = emailLink.dataset.email ?? "info@thedatum.ai";

        const showCopied = () => {
          emailLink.dataset.copied = "";
          window.clearTimeout(copiedTimer);
          copiedTimer = window.setTimeout(() => {
            delete emailLink.dataset.copied;
          }, 1500);
        };

        // Hard fallback for the (rare) case where both copy paths fail —
        // surface mailto: so the user still has a way to reach the address.
        const fallbackToMailto = () => {
          window.location.href = `mailto:${email}`;
        };

        if (navigator.clipboard?.writeText) {
          navigator.clipboard.writeText(email).then(showCopied).catch(() => {
            // Try the legacy execCommand path before giving up.
            if (legacyCopy(email)) showCopied();
            else fallbackToMailto();
          });
        } else if (legacyCopy(email)) {
          showCopied();
        } else {
          fallbackToMailto();
        }
      });
    }

    // Legacy execCommand("copy") helper — used when clipboard API is missing
    // (insecure context, older Safari) or blocked by permissions.
    function legacyCopy(text: string): boolean {
      try {
        const ta = document.createElement("textarea");
        ta.value = text;
        ta.setAttribute("readonly", "");
        ta.style.position = "fixed";
        ta.style.opacity = "0";
        document.body.appendChild(ta);
        ta.select();
        const ok = document.execCommand("copy");
        document.body.removeChild(ta);
        return ok;
      } catch {
        return false;
      }
    }

    // ─── Chat — drives sphere state per the sphere2.0 demo loop ───────
    if (chatInput && chatForm && chatSend && chatMessages) {
      let busy = false;

      const setBusy = (v: boolean) => {
        busy = v;
        chatSend.disabled = v;
        chatInput.disabled = v;
      };

      const addMessage = (role: "user" | "bot", text: string) => {
        const msg = document.createElement("p");
        msg.className = `navbar__chat-msg navbar__chat-msg--${role}`;
        msg.textContent = text;
        chatMessages.appendChild(msg);
        chatMessages.scrollTop = chatMessages.scrollHeight;
        return msg;
      };

      const sleep = (ms: number) => new Promise<void>((r) => setTimeout(r, ms));

      const streamMessage = async (role: "bot", text: string) => {
        const msg = addMessage(role, "");
        const words = text.split(" ");
        const last = words.length - 1;
        for (let i = 0; i < words.length; i++) {
          msg.textContent += (i > 0 ? " " : "") + words[i];
          chatMessages.scrollTop = chatMessages.scrollHeight;
          // Per-word brightness burst — orb visibly "speaks"
          sphere?.speakPulse();
          // Last 2 words: start easing the orb back toward normal
          if (i === last - 1) sphere?.applyTargetParams("normal");
          await sleep(70 + Math.random() * 110);
        }
      };

      // Focus → listening; blur (empty) → normal
      chatInput.addEventListener("focus", () => {
        if (!busy) sphere?.setState("listening" satisfies SphereState);
      });
      chatInput.addEventListener("blur", () => {
        if (!busy && !chatInput.value.trim()) sphere?.setState("normal");
      });

      chatForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        const text = chatInput.value.trim();
        if (!text || busy) return;
        setBusy(true);
        addMessage("user", text);
        chatInput.value = "";

        sphere?.setState("thinking");
        // Shortened from the demo's 6.6–11.4s — feels right for nav-widget tempo
        await sleep(1600 + Math.random() * 1200);

        sphere?.setState("speaking");
        await streamMessage("bot", pickResponse(text));

        sphere?.setState("normal");
        setBusy(false);
      });

      // Suggestion chips — clicking one drops it into the input as a prompt
      chips.forEach((chip) => {
        chip.addEventListener("click", () => {
          const value = chip.dataset.chip ?? chip.textContent ?? "";
          chatInput.value = value;
          chatInput.focus();
        });
      });
    }
  }
</script>
