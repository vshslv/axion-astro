    background: var(--color-glass);
    color: var(--color-fg);
    padding-block: 0.3125rem;
    padding-inline: 0.625rem;
    border-radius: var(--radius-pill);
    /* Same specular rim as liquid buttons. Applied directly (no
       multi-layer .liquid stack) because Send is tiny and doesn't
       need the displacement filter — just the highlight feel. */
    box-shadow:
      inset 0 1px 1px -0.5px rgba(255, 255, 255, 0.4),
      inset 0 -1px 1px -0.5px rgba(255, 255, 255, 0.18);
