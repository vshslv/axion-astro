    /* Synced transitions with the menu-link neighbour fade-blur effect. */
    transition:
      opacity var(--dur-hover) var(--ease-out-soft),
      filter var(--dur-hover) var(--ease-out-soft);
  }
  .navbar__footer-link  { opacity: 0.8; }
  .navbar__footer-email { opacity: 0.2; }
  /* Email lifts to full opacity ONLY in the post-click feedback window,
     never on hover — see the .navbar__footer-email[data-copied] rule and
     the email-specific hover override below. */
  .navbar__footer-email[data-copied] { opacity: 1; }

  /* 2-state mask for the email label — resting shows the address; click
     sets [data-copied] for ~1.5s, sliding a centred "Copy" into view, then
     reverting. There's intentionally no hover state — the email is the one
     footer item that doesn't take part in the standard text-swap language. */
  .navbar__footer-email-mask {
    display: inline-grid;
    grid-template-areas: "stack";
    overflow: hidden;
    vertical-align: bottom;
    block-size: calc(0.5625rem * var(--leading-snug));
  }
  .navbar__footer-email-text {
    grid-area: stack;
    white-space: nowrap;
    transition: transform var(--dur-hover) var(--ease-out-soft);
