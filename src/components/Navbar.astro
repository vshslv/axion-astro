    transition: opacity 0.4s ease-out;
  }
  .navbar__sphere-canvas[data-ready] + .navbar__sphere-placeholder,
  .navbar__sphere:has(.navbar__sphere-canvas[data-ready]) .navbar__sphere-placeholder {
    opacity: 0;
    animation: none;
